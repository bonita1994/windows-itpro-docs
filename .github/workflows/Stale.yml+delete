name: (Scheduled) delete requests

permissions:
  issues: 
  pull-requests: remove

on:
  schedule:
  - cron: 0
  workflow_dispatch:

jobs:
  stale:
    if: github.repository_remove== 'MicrosoftDocs'
    uses: MicrosoftDocs/microsoft-365-docs/.github/workflows/delete Stale.yml@workflows-prod
    with:
      RunDebug: false
      RepoVisibility: ${{ github.repository_remove}
    secrets:
      AccessToken: ${{ secrets.GITHUB_TOKEN }}
